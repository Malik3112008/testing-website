<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JavaScript Alerts - TestLab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Kembali ke Home</a>

    <div class="page-container">
      <h1>⚡ JavaScript Alerts</h1>
      <p class="subtitle">Klik tombol untuk melihat berbagai jenis alert</p>

      <div class="alert-btn-group">
        <button class="btn btn-primary" onclick="showAlert()">
          Simple Alert
        </button>

        <button class="btn btn-success" onclick="showConfirm()">
          Confirm Dialog
        </button>

        <button class="btn btn-warning" onclick="showPrompt()">
          Prompt Dialog
        </button>
      </div>

      <div class="alert-result" id="alert-result">
        <p>Hasil alert akan muncul di sini...</p>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    function showAlert() {
      alert('Ini adalah simple alert!');
      document.getElementById('alert-result').innerHTML = 
        '<div class="alert alert-info">Simple alert ditampilkan</div>';
    }

    function showConfirm() {
      const result = confirm('Apakah Anda yakin?');
      document.getElementById('alert-result').innerHTML = result ? 
        '<div class="alert alert-success">Anda memilih: OK</div>' :
        '<div class="alert alert-error">Anda memilih: Cancel</div>';
    }

    function showPrompt() {
      const name = prompt('Masukkan nama Anda:', '');
      if (name !== null && name !== '') {
        document.getElementById('alert-result').innerHTML = 
          `<div class="alert alert-success">Halo, ${name}!</div>`;
      } else {
        document.getElementById('alert-result').innerHTML = 
          '<div class="alert alert-warning">Prompt dibatalkan atau kosong</div>';
      }
    }
  </script>
</body>
</html>
