<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Testing Website - Modern Playground</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
        <li><a href="/dynamic-loading">Dynamic Loading</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <div class="hero">
      <h1>🚀 Testing Playground</h1>
      <p>Website modern untuk testing Playwright automation. Pilih fitur di bawah untuk mulai testing.</p>
    </div>

    <div class="cards-grid">
      <div class="card">
        <div class="card-icon">🔐</div>
        <h3>Login</h3>
        <p>Form authentication dengan validasi login</p>
        <a href="/login" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">☑️</div>
        <h3>Checkboxes</h3>
        <p>Checkbox interaktif dengan berbagai state</p>
        <a href="/checkboxes" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">📋</div>
        <h3>Dropdown</h3>
        <p>Dropdown select dengan multiple options</p>
        <a href="/dropdown" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">⏳</div>
        <h3>Dynamic Loading</h3>
        <p>Content yang muncul setelah loading</p>
        <a href="/dynamic-loading" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">📝</div>
        <h3>Form Inputs</h3>
        <p>Berbagai jenis input form</p>
        <a href="/form-inputs" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">⚡</div>
        <h3>JavaScript Alerts</h3>
        <p>Alert, confirm, dan prompt dialogs</p>
        <a href="/javascript-alerts" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">📤</div>
        <h3>File Upload</h3>
        <p>Upload file dengan drag and drop</p>
        <a href="/file-upload" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">🔀</div>
        <h3>Drag and Drop</h3>
        <p>Drag element ke target area</p>
        <a href="/drag-and-drop" class="btn">Coba Sekarang</a>
      </div>

      <div class="card">
        <div class="card-icon">🖱️</div>
        <h3>Hover</h3>
        <p>Hover effect dan tooltip</p>
        <a href="/hover" class="btn">Coba Sekarang</a>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>Testing Website © 2026 - Built for Playwright Automation</p>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
