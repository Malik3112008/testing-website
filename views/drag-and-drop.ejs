<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Drag and Drop - TestLab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Kembali ke Home</a>

    <div class="page-container">
      <h1>🔀 Drag and Drop</h1>
      <p class="subtitle">Seret item dari area sumber ke area target</p>

      <div class="drag-container">
        <div class="drop-zone" id="source-zone">
          <h3>📦 Sumber</h3>
          <div class="draggable-item" draggable="true" data-id="1">Item 1</div>
          <div class="draggable-item" draggable="true" data-id="2">Item 2</div>
          <div class="draggable-item" draggable="true" data-id="3">Item 3</div>
        </div>

        <div class="drop-zone" id="target-zone">
          <h3>🎯 Target</h3>
          <p style="color: var(--gray);">Seret item ke sini</p>
        </div>
      </div>

      <div class="result-box" id="result-box" style="margin-top: 2rem;">
        <h3>Status:</h3>
        <p id="drag-result">Belum ada item yang dipindahkan</p>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    const sourceZone = document.getElementById('source-zone');
    const targetZone = document.getElementById('target-zone');
    const resultText = document.getElementById('drag-result');
    const resultBox = document.getElementById('result-box');
    let draggedItem = null;

    document.querySelectorAll('.draggable-item').forEach(item => {
      item.addEventListener('dragstart', (e) => {
        draggedItem = item;
        item.style.opacity = '0.5';
        e.dataTransfer.effectAllowed = 'move';
      });

      item.addEventListener('dragend', () => {
        item.style.opacity = '1';
        draggedItem = null;
      });
    });

    [sourceZone, targetZone].forEach(zone => {
      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('active');
      });

      zone.addEventListener('dragleave', () => {
        zone.classList.remove('active');
      });

      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('active');
        
        if (draggedItem) {
          zone.appendChild(draggedItem);
          updateResult();
        }
      });
    });

    function updateResult() {
      const targetItems = targetZone.querySelectorAll('.draggable-item');
      if (targetItems.length > 0) {
        const items = Array.from(targetItems).map(i => i.textContent).join(', ');
        resultText.textContent = `Item di target: ${items}`;
        resultBox.classList.add('active');
      } else {
        resultText.textContent = 'Belum ada item yang dipindahkan';
        resultBox.classList.remove('active');
      }
    }
  </script>
</body>
</html>
