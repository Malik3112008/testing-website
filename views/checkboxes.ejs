<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkboxes - TestLab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Kembali ke Home</a>

    <div class="page-container">
      <h1>☑️ Checkboxes</h1>
      <p class="subtitle">Pilih atau取消 pilih checkbox di bawah ini</p>

      <div class="checkbox-group">
        <div class="checkbox-item">
          <input type="checkbox" id="checkbox-1" name="option1" value="1">
          <label for="checkbox-1">Option 1</label>
        </div>

        <div class="checkbox-item">
          <input type="checkbox" id="checkbox-2" name="option2" value="2">
          <label for="checkbox-2">Option 2</label>
        </div>

        <div class="checkbox-item">
          <input type="checkbox" id="checkbox-3" name="option3" value="3" checked>
          <label for="checkbox-3">Option 3 (Default Checked)</label>
        </div>

        <div class="checkbox-item">
          <input type="checkbox" id="checkbox-4" name="option4" value="4" disabled>
          <label for="checkbox-4">Option 4 (Disabled)</label>
        </div>
      </div>

      <div class="result-box" id="result-box" style="margin-top: 2rem;">
        <h3>Hasil Pilihan:</h3>
        <p id="checkbox-result">Belum ada pilihan</p>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    const checkboxes = document.querySelectorAll('input[type="checkbox"]:not([disabled])');
    const resultText = document.getElementById('checkbox-result');
    const resultBox = document.getElementById('result-box');

    function updateResult() {
      const checked = [];
      checkboxes.forEach(cb => {
        if (cb.checked) checked.push(cb.parentElement.querySelector('label').textContent);
      });

      if (checked.length > 0) {
        resultText.textContent = checked.join(', ');
        resultBox.classList.add('active');
      } else {
        resultText.textContent = 'Belum ada pilihan';
        resultBox.classList.remove('active');
      }
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', updateResult);
    });
  </script>
</body>
</html>
