<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hover - TestLab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Kembali ke Home</a>

    <div class="page-container">
      <h1>🖱️ Hover Effects</h1>
      <p class="subtitle">Arahkan mouse ke card untuk melihat efek hover</p>

      <div class="hover-grid">
        <div class="hover-card" id="hover-card-1">
          <div class="hover-icon">🚀</div>
          <h3>Fast</h3>
          <div class="hover-content">
            <p>Performa tinggi untuk kebutuhan Anda</p>
          </div>
        </div>

        <div class="hover-card" id="hover-card-2">
          <div class="hover-icon">🔒</div>
          <h3>Secure</h3>
          <div class="hover-content">
            <p>Keamanan data terjamin</p>
          </div>
        </div>

        <div class="hover-card" id="hover-card-3">
          <div class="hover-icon">💡</div>
          <h3>Smart</h3>
          <div class="hover-content">
            <p>Solusi cerdas untuk masalah Anda</p>
          </div>
        </div>

        <div class="hover-card" id="hover-card-4">
          <div class="hover-icon">🎯</div>
          <h3>Precise</h3>
          <div class="hover-content">
            <p>Hasil akurat dan tepat sasaran</p>
          </div>
        </div>
      </div>

      <div class="result-box" id="result-box" style="margin-top: 2rem;">
        <h3>Hover Log:</h3>
        <p id="hover-result">Arahkan mouse ke card di atas</p>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script>
    const cards = document.querySelectorAll('.hover-card');
    const resultText = document.getElementById('hover-result');
    const resultBox = document.getElementById('result-box');

    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const name = card.querySelector('h3').textContent;
        resultText.textContent = `Mouse masuk ke: ${name}`;
        resultBox.classList.add('active');
      });

      card.addEventListener('mouseleave', () => {
        resultText.textContent = 'Arahkan mouse ke card di atas';
        resultBox.classList.remove('active');
      });
    });
  </script>
</body>
</html>
