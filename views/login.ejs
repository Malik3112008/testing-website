<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - TestLab</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎯 TestLab</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/checkboxes">Checkboxes</a></li>
        <li><a href="/dropdown">Dropdown</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <a href="/" class="back-link">← Kembali ke Home</a>

    <div class="page-container" style="max-width: 400px; margin: 0 auto;">
      <h1>🔐 Login</h1>
      <p class="subtitle">Masukkan credentials untuk login</p>

      <% if (error) { %>
        <div class="alert alert-error" id="error-message">
          <%= error %>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success" id="success-message">
          <%= success %>
        </div>
      <% } %>

      <form action="/login" method="POST" id="login-form">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Masukkan username" required>
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Masukkan password" required>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">
          Login
        </button>
      </form>

      <div class="alert alert-info" style="margin-top: 1.5rem;">
        <strong>Demo:</strong> username: <code>admin</code> | password: <code>admin123</code>
      </div>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
